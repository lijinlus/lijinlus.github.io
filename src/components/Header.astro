---
import { SITE_TITLE, NAV_LINKS } from "../consts";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="site-header">
  <div class="wrapper inner">
    <a class="brand" href="/">{SITE_TITLE}</a>
    <nav>
      {
        NAV_LINKS.map((link) => (
          <a href={link.href} class:list={[{ active: isActive(link.href) }]}>
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    padding-block: 1.25rem;
  }
  .inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .brand {
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--text);
    border: none;
    letter-spacing: -0.01em;
  }
  .brand:hover {
    background: none;
    color: var(--accent);
  }
  nav {
    display: flex;
    gap: 1.25rem;
    font-size: 0.95rem;
  }
  nav a {
    color: var(--text-muted);
    border: none;
  }
  nav a:hover {
    background: none;
    color: var(--accent);
  }
  nav a.active {
    color: var(--text);
    font-weight: 600;
  }
</style>
