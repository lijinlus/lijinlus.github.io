---
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import type { MarkdownHeading } from "astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  headings?: MarkdownHeading[];
}
const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  headings = [],
} = Astro.props;

// 目录只取 h2/h3，避免过深
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="post-head">
      <h1>{title}</h1>
      <p class="meta">
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <span class="muted"> · 更新于 <FormattedDate date={updatedDate} /></span>
          )
        }
      </p>
      {
        tags.length > 0 && (
          <ul class="tags">
            {tags.map((t) => (
              <li>{t}</li>
            ))}
          </ul>
        )
      }
    </header>

    {
      toc.length > 1 && (
        <nav class="toc" aria-label="目录">
          <p class="toc-title">目录</p>
          <ul>
            {toc.map((h) => (
              <li class:list={[{ sub: h.depth === 3 }]}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <div class="prose">
      <slot />
    </div>
  </article>

  <style>
    .post-head {
      margin-bottom: 2.5rem;
    }
    .post-head h1 {
      margin-bottom: 0.5rem;
    }
    .meta {
      color: var(--text-muted);
      font-size: 0.95rem;
      margin: 0;
    }
    .tags {
      list-style: none;
      padding: 0;
      margin: 0.75rem 0 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .tags li {
      font-size: 0.8rem;
      color: var(--text-muted);
      background: var(--code-bg);
      padding: 0.1rem 0.6rem;
      border-radius: 999px;
      margin: 0;
    }
    .toc {
      font-size: 0.9rem;
      background: var(--code-bg);
      border: 1px solid var(--rule);
      border-radius: 6px;
      padding: 1rem 1.25rem;
      margin-bottom: 2.5rem;
    }
    .toc-title {
      font-weight: 700;
      margin: 0 0 0.5rem;
      font-size: 0.85rem;
      letter-spacing: 0.03em;
      color: var(--text-muted);
    }
    .toc ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .toc li {
      margin: 0.25rem 0;
    }
    .toc li.sub {
      padding-left: 1.25rem;
    }
    .toc a {
      border: none;
      color: var(--text-muted);
    }
    .toc a:hover {
      background: none;
      color: var(--accent);
    }
  </style>
</BaseLayout>
